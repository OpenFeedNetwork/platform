{
  "name": "open-feed-platform",
  "version": "1.0.0",
  "description": "Open Feed Algorithm — Anti-suppression social platform with Truth Shield & Guardian Shield",
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev":              "concurrently \"npm run dev:gateway\" \"npm run dev:truth\" \"npm run dev:guardian\" \"npm run dev:ofa\"",
    "dev:gateway":      "node --watch services/gateway/index.js",
    "dev:truth":        "node --watch services/truth-shield/index.js",
    "dev:guardian":     "node --watch services/guardian-shield/index.js",
    "dev:ofa":          "node --watch services/ofa-feed/index.js",
    "build":            "echo 'No build step required — pure ESM'",
    "start":            "node services/gateway/index.js",
    "lint":             "eslint services/ --ext .js",
    "test":             "node --experimental-vm-modules node_modules/.bin/jest",
    "db:migrate":       "node scripts/migrate.js",
    "db:seed":          "node scripts/seed.js",
    "docker:build":     "docker compose build",
    "docker:up":        "docker compose up -d",
    "docker:down":      "docker compose down",
    "docker:logs":      "docker compose logs -f",
    "docker:reset":     "docker compose down -v && docker compose up -d"
  },
  "dependencies": {
    "@anthropic-ai/sdk":    "^0.27.0",
    "better-sqlite3":       "^9.4.3",
    "bullmq":               "^5.4.2",
    "compression":          "^1.7.4",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-rate-limit":   "^7.2.0",
    "helmet":               "^7.1.0",
    "http-proxy-middleware": "^3.0.0",
    "ioredis":              "^5.3.2",
    "morgan":               "^1.10.0",
    "uuid":                 "^9.0.1",
    "winston":              "^3.13.0"
  },
  "devDependencies": {
    "concurrently":  "^8.2.2",
    "eslint":        "^9.2.0",
    "jest":          "^29.7.0",
    "supertest":     "^7.0.0"
  }
}
